# SynoHub application secrets
AUTH_SECRET=replace-with-a-long-random-string
ADMIN_PASSWORD=replace-with-a-strong-admin-password
STAFF_PASSWORD=replace-with-a-shared-staff-password

# DATABASE CONFIG
DB_HOST=127.0.0.1
DB_PORT=3307
DB_SOCKET=
DB_USER=root
DB_PASSWORD=
DB_NAME=synohub

# LOCAL LLM CONFIG
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_NUM_THREAD=6
OLLAMA_NUM_GPU=-1
OLLAMA_NUM_CTX=2048
OLLAMA_KEEP_ALIVE=60m

# GEMINI CONFIG (primary cloud provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# NEX AGI / OPENROUTER CONFIG (fallback when Gemini key is not configured)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SynoHub
# Cohere compare provider, served through OpenRouter
OPENROUTER_COMPARE_MODEL=cohere/north-mini-code:free
OPENROUTER_COMPARE_REASONING=true
